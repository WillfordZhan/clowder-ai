{
  "name": "@cat-cafe/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --exclude \"dist/**\" --exclude \"../shared/dist/**\" src/index.ts",
    "build": "pnpm --dir ../shared build && tsc && node ./scripts/copy-marketplace-catalog-data.mjs",
    "start": "node dist/index.js",
    "test": "pnpm run build && CAT_CAFE_DISABLE_SHARED_STATE_PREFLIGHT=1 bash ./scripts/with-test-home.sh node --import $(pwd)/test/helpers/setup-cat-registry.js --test --test-timeout=60000 test/*.test.js test/**/*.test.js && pnpm run test:cli",
    "test:public": "pnpm --dir ../shared build && pnpm --dir ../mcp-server build && pnpm run build && CAT_CAFE_DISABLE_SHARED_STATE_PREFLIGHT=1 bash ./scripts/with-test-home.sh bash ./scripts/run-public-tests.sh",
    "test:antigravity-smoke": "RUN_ANTIGRAVITY_SMOKE=true pnpm run build && RUN_ANTIGRAVITY_SMOKE=true bash ./scripts/with-test-home.sh node --test test/antigravity-smoke.test.js",
    "smoke:f210-agy-profiles": "pnpm run build && node dist/scripts/f210-agy-profile-smoke.js",
    "fetch-signals": "node dist/scripts/fetch-signals.js",
    "migrate-signals": "node dist/scripts/migrate-signals.js",
    "rebuild-index": "node dist/scripts/rebuild-index.js",
    "project:init": "node dist/scripts/project-init.js",
    "test:redis": "bash ./scripts/with-test-home.sh bash ./scripts/run-isolated-redis-tests.sh",
    "test:redis:repeat": "bash ./scripts/with-test-home.sh bash ./scripts/run-isolated-redis-tests.sh --repeat 2",
    "test:integration": "bash ./scripts/with-test-home.sh node --test test/integration/*.test.js",
    "test:pty": "pnpm run build && node --import $(pwd)/test/helpers/setup-cat-registry.js --test --test-timeout=120000 test/f230-pty-driver.test.js",
    "test:cli": "node --import tsx --test test/cli/*.test.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cat-cafe/shared": "workspace:*",
    "@fastify/cookie": "9",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "8",
    "@fastify/static": "7",
    "@fastify/websocket": "^10.0.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@vscode/ripgrep": "1.18.0",
    "@wecom/aibot-node-sdk": "1.0.4",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.1.2",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "2.1.6-beta.1",
    "fast-xml-parser": "^5.5.9",
    "fastify": "^4.25.0",
    "grammy": "^1.41.1",
    "http-proxy": "^1.18.1",
    "js-tiktoken": "^1.0.21",
    "nanoid": "^3.3.11",
    "node-pty": "1.2.0-beta.12",
    "nodemailer": "^6.9.16",
    "pino-roll": "^4.0.0",
    "puppeteer-core": "^24.37.2",
    "qrcode": "^1.5.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "silk-wasm": "^3.7.1",
    "smol-toml": "^1.6.0",
    "socket.io": "^4.7.0",
    "sqlite-vec": "^0.1.9",
    "web-push": "^3.6.7",
    "ws": "^8.18.0",
    "yaml": "^2.8.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "ioredis": "^5.3.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.0",
    "fast-check": "^4.5.3",
    "jsdom": "^28.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
